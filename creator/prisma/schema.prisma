generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ----------------------------------------------------
// 1. UTILISATEURS & AUTH
// ----------------------------------------------------
model User {
  id               String   @id @default(uuid())
  email            String   @unique
  passwordHash     String
  role             String   @default("CLIENT") // "CREATOR", "CLIENT", "ADMIN"
  
  // Profil
  displayName      String?
  username         String?  @unique
  avatarUrl        String?
  bio              String?
  bannerUrl        String?
  
  // Paramètres Créateur
  subscriptionPrice Float     @default(0.0)
  balance          Float     @default(0.0)

  // Timestamps
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  sentMessages     Message[]         @relation("SentMessages")
  conversations    ConversationParticipant[]
  libraryFolders   LibraryFolder[]
  libraryItems     LibraryItem[]
}

// ----------------------------------------------------
// 2. MESSAGERIE (Chat & Conversations)
// ----------------------------------------------------
model Conversation {
  id               String   @id @default(uuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  participants     ConversationParticipant[]
  messages         Message[]
}

model ConversationParticipant {
  id               String   @id @default(uuid())
  conversationId   String
  userId           String
  joinedAt         DateTime @default(now())
  lastReadAt       DateTime @default(now())

  // Relations
  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId]) // Un user ne peut être qu'une fois dans une conv
}

model Message {
  id               String   @id @default(uuid())
  conversationId   String
  senderId         String
  content          String?  // Texte du message (optionnel si c'est juste un média)
  
  // Spécifique aux médias payants
  isPaid           Boolean  @default(false)
  price            Float?
  isUnlocked       Boolean  @default(false) // Vrai si le destinaire l'a acheté
  
  createdAt        DateTime @default(now())

  // Relations
  conversation     Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender           User          @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  mediaAttachments MessageMedia[]
}

// Table de liaison entre un Message et un ou plusieurs LibraryItem
model MessageMedia {
  id               String   @id @default(uuid())
  messageId        String
  libraryItemId    String

  message          Message     @relation(fields: [messageId], references: [id], onDelete: Cascade)
  libraryItem      LibraryItem @relation(fields: [libraryItemId], references: [id], onDelete: Cascade)

  @@unique([messageId, libraryItemId])
}

// ----------------------------------------------------
// 3. BIBLIOTHÈQUE PRIVÉE (Private Library)
// ----------------------------------------------------
model LibraryFolder {
  id               String   @id @default(uuid())
  creatorId        String
  title            String
  description      String?
  coverUrl         String?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  creator          User          @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  items            LibraryItem[]
}

model LibraryItem {
  id               String   @id @default(uuid())
  creatorId        String
  folderId         String?
  
  url              String
  type             String   // "image" | "video"
  filename         String?
  sizeBytes        Int?
  
  createdAt        DateTime @default(now())

  // Relations
  creator          User           @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  folder           LibraryFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  messageLinks     MessageMedia[]
}
